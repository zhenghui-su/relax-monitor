{
	"name": "@relaxwork/monitor",
	"version": "1.0.0",
	"description": "A lightweight JS monitor SDK",
	"main": "index.js",
	"scripts": {
		"error:build": "pnpm --filter @relaxwork/error-monitor build",
		"error:demo": "pnpm --filter @relaxwork/error-monitor demo",
		"behavior:build": "pnpm --filter @relaxwork/behavior-monitor build",
		"behavior:demo": "pnpm --filter @relaxwork/behavior-monitor demo",
		"performance:build": "pnpm --filter @relaxwork/performance-monitor build",
		"performance:demo": "pnpm --filter @relaxwork/performance-monitor demo",
		"build": "pnpm run error:build && pnpm run behavior:build && pnpm run performance:build",
		"release": "tsx scripts/index.ts",
		"release:dry": "tsx scripts/index.ts --dry-run"
	},
	"keywords": [
		"relaxwork monitor",
		"frontend",
		"javascript",
		"sdk"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zhenghui-su/relax-monitor.git"
	},
	"homepage": "https://github.com/zhenghui-su/relax-monitor",
	"bugs": {
		"url": "https://github.com/zhenghui-su/relax-monitor/issues"
	},
	"author": {
		"name": "zhenghui-su",
		"email": "suzhenghui2003@qq.com"
	},
	"license": "MIT",
	"packageManager": "pnpm@10.33.0",
	"devDependencies": {
		"@inquirer/prompts": "^8.4.1",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^25.6.0",
		"@types/semver": "^7.7.1",
		"picocolors": "^1.1.1",
		"rollup": "^4.60.1",
		"semver": "^7.7.4",
		"string-width": "^8.2.0",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
